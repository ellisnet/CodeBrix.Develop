<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <!-- SITUATIONAL EXCEPTION (documented): this project keeps
         <Nullable>enable</Nullable> because it builds directly against the
         CodeBrix.Develop.UI binding (NRT-annotated API surface) and its
         GObject-subclass Roslyn source generator, which emits
         nullable-enabled code (same rationale as CodeBrix.Develop.UI
         itself). CodeBrix.Develop.Core stays NRT-off per family convention. -->
    <Nullable>enable</Nullable>
    <!-- The GObject subclass source generator emits unsafe code. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CodeBrix.Develop.UI" Version="1.0.202.186" />
  </ItemGroup>

  <ItemGroup>
    <!-- MonoDevelop icon assets: assumed LGPL 2.1, used UNMODIFIED only
         (see THIRD-PARTY-NOTICES.txt; the LGPL text is the COPYING file
         beside the images). Looked up at run time by ImageService. -->
    <EmbeddedResource Include="Assets\MonoDevelopIcons\*.png" LogicalName="icons/%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <!-- Visual Studio Code color theme definitions: unmodified JSON from
         the MIT-licensed microsoft/vscode repository (see
         THIRD-PARTY-NOTICES.txt; the MIT text is the LICENSE.txt file
         beside the themes). Translated at run time by ThemeService. -->
    <EmbeddedResource Include="Assets\VSCodeThemes\*.json" LogicalName="themes/%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CodeBrix.Develop.Core\CodeBrix.Develop.Core.csproj" />
  </ItemGroup>

</Project>
